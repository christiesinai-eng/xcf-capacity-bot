# Asana API
ASANA_TOKEN=your_asana_personal_access_token_here
ASANA_WORKSPACE_GID=your_workspace_gid_here

# Asana Custom Field GIDs
ASANA_FIELD_GID_ESTIMATED_TIME=your_estimated_time_field_gid

# Optional: GID of the custom field that stores each member's POD name.
# If omitted, all members show pod: "Unknown".
# POD values must match: Performance | Design | Design Studio | Campaign | AI & Media | Campaign Ops | GM Creative
ASANA_FIELD_GID_POD=

# Slack API
SLACK_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=your_channel_id_here
